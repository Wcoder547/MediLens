<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Medicine Name -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Medicine Name *"
            android:layout_marginBottom="12dp"
            app:boxStrokeColor="@color/primary"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etMedicineName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textCapWords"
                android:imeOptions="actionNext" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Dose -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Dose (e.g. 500mg, 20mg)"
            android:layout_marginBottom="12dp"
            app:boxStrokeColor="@color/primary"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etDose"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                android:imeOptions="actionNext" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Form -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Form (tablet / syrup / inhaler…)"
            android:layout_marginBottom="12dp"
            app:boxStrokeColor="@color/primary"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etForm"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                android:imeOptions="actionNext" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Duration -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Duration (e.g. 7 days, 2 weeks)"
            android:layout_marginBottom="12dp"
            app:boxStrokeColor="@color/primary"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etDuration"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                android:imeOptions="actionNext" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Instructions -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Instructions (e.g. after meals)"
            android:layout_marginBottom="12dp"
            app:boxStrokeColor="@color/primary"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etInstructions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                android:imeOptions="actionNext" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Quantity per dose -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Quantity per dose (e.g. 1, 2)"
            android:layout_marginBottom="16dp"
            app:boxStrokeColor="@color/primary"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etQuantity"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:imeOptions="actionDone" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Frequency -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Frequency"
            android:textSize="14sp"
            android:textColor="@color/on_surface_variant"
            android:layout_marginBottom="6dp" />

        <RadioGroup
            android:id="@+id/rgFrequency"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <RadioButton
                android:id="@+id/rbOnceDaily"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Once"
                android:layout_marginEnd="16dp" />

            <RadioButton
                android:id="@+id/rbTwiceDaily"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Twice"
                android:layout_marginEnd="16dp" />

            <RadioButton
                android:id="@+id/rbThriceDaily"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="3×" />

        </RadioGroup>

        <!-- Time slots -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Schedule Times"
            android:textSize="14sp"
            android:textColor="@color/on_surface_variant"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnTime1"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Set time"
            android:textSize="14sp"
            app:backgroundTint="@android:color/transparent"
            app:strokeColor="@color/primary"
            app:strokeWidth="1dp"
            android:textColor="@color/primary"
            app:cornerRadius="8dp"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnTime2"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Set time"
            android:textSize="14sp"
            app:backgroundTint="@android:color/transparent"
            app:strokeColor="@color/primary"
            app:strokeWidth="1dp"
            android:textColor="@color/primary"
            app:cornerRadius="8dp"
            android:layout_marginBottom="8dp"
            android:visibility="gone" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnTime3"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Set time"
            android:textSize="14sp"
            app:backgroundTint="@android:color/transparent"
            app:strokeColor="@color/primary"
            app:strokeWidth="1dp"
            android:textColor="@color/primary"
            app:cornerRadius="8dp"
            android:visibility="gone" />

    </LinearLayout>

</ScrollView>
