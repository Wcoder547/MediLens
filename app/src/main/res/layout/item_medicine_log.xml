<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp">

        <ImageView
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@layout/ic_rx"
            android:contentDescription="Pill"
            android:layout_gravity="center_vertical"
            android:scaleType="centerCrop" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp">

            <TextView
                android:id="@+id/tvMedicineName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Aspirin"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/primaryText"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tvTimeDosage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="8:00 AM • 100mg"
                android:textSize="14sp"
                android:textColor="@color/subtext"
                android:layout_marginTop="2dp" />

        </LinearLayout>

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pending"
            android:textSize="12sp"
            android:paddingHorizontal="12dp"
            android:paddingVertical="6dp"
            android:layout_gravity="center_vertical"
            android:textStyle="bold"
            android:minWidth="60dp"
            android:gravity="center" />

        <!-- Fixed: Removed deprecated icon + problematic style -->
        <Button
            android:id="@+id/btnMarkTaken"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_marginStart="8dp"
            android:text="Taken"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@color/primary"
            android:background="@drawable/bg_button_transparent"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:paddingHorizontal="16dp" />

    </LinearLayout>

</androidx.cardview.widget.CardView>
