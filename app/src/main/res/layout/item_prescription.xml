<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:background="@color/white">

        <ImageButton
            android:id="@+id/btnMore"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="end"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="More options"
            android:padding="8dp"
            android:src="@drawable/ic_more_vert"
            app:tint="@color/on_surface_variant" />

        <!-- Prescription Name (Bold Title) -->
        <TextView
            android:id="@+id/tvPrescriptionName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Morning Meds"
            android:textColor="@color/on_surface"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp"
            tools:text="Morning Meds" />

        <!-- Drug Name & Dosage Chips -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <com.google.android.material.chip.Chip
                android:id="@+id/chipDrugName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Paracetamol"
                android:textColor="@color/primary"
                app:chipBackgroundColor="@color/primary_container"
                app:chipStrokeColor="@color/primary"
                app:chipStrokeWidth="1dp"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_marginEnd="12dp"
                tools:text="Paracetamol" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipDosage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1 tablet"
                android:textColor="@color/secondary"
                app:chipBackgroundColor="@color/secondary_container"
                app:chipStrokeColor="@color/secondary"
                app:chipStrokeWidth="1dp"
                style="@style/Widget.Material3.Chip.Filter"
                tools:text="1 tablet" />

        </LinearLayout>

        <!-- Frequency Tag -->
        <com.google.android.material.chip.ChipGroup
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">

            <com.google.android.material.chip.Chip
                android:id="@+id/tvFrequency"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Three Times Daily"
                android:textColor="@color/white"
                app:chipBackgroundColor="@color/primary"
                app:chipStrokeColor="@color/primary"
                app:chipStrokeWidth="0dp"
                style="@style/Widget.Material3.Chip.Filter"
                tools:text="Three Times Daily" />

        </com.google.android.material.chip.ChipGroup>

        <!-- BEAUTIFUL DOSAGE SECTION -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_dosage_section"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Dosage Details"
                android:textColor="@color/primary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvDosageDetails"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Take 1 tablet per dose\nTotal pack: 10 tablets"
                android:textColor="@color/on_surface"
                android:textSize="15sp"
                android:lineSpacingExtra="2dp"
                tools:text="Take 1 tablet per dose\nTotal pack: 10 tablets" />

        </LinearLayout>

        <!-- BEAUTIFUL TIME SCHEDULE SECTION -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_time_section"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Schedule"
                android:textColor="@color/secondary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:id="@+id/tvTimes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <com.google.android.material.chip.Chip
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="8:00 AM"
                    android:textColor="@color/white"
                    app:chipBackgroundColor="#4CAF50"
                    app:chipStrokeWidth="0dp"
                    style="@style/Widget.Material3.Chip.Suggestion"
                    android:layout_marginEnd="8dp" />

                <com.google.android.material.chip.Chip
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2:00 PM"
                    android:textColor="@color/white"
                    app:chipBackgroundColor="#2196F3"
                    app:chipStrokeWidth="0dp"
                    style="@style/Widget.Material3.Chip.Suggestion"
                    android:layout_marginEnd="8dp" />

                <com.google.android.material.chip.Chip
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="8:00 PM"
                    android:textColor="@color/white"
                    app:chipBackgroundColor="#FF9800"
                    app:chipStrokeWidth="0dp"
                    style="@style/Widget.Material3.Chip.Suggestion" />

            </LinearLayout>

        </LinearLayout>

        <!-- Notes -->
        <TextView
            android:id="@+id/tvNotes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Take after meals"
            android:textColor="@color/outline"
            android:textSize="12sp"
            android:paddingTop="8dp"
            tools:text="Take after meals" />

        <!-- More Button -->


    </LinearLayout>

</androidx.cardview.widget.CardView>
